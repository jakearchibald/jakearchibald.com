{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "es2025",
    "module": "esnext",
    "jsx": "react",
    "jsxFactory": "h",
    "strict": true,
    "moduleResolution": "bundler",
    "outDir": ".tmp/ts",
    "composite": true,
    "declarationMap": true,
    "rootDir": "./",
    "allowSyntheticDefaultImports": true
  }
}
